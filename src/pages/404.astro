---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Ethan's Blog" description="페이지를 찾을 수 없습니다">
  <div class="flex flex-col items-center justify-center py-20 text-center">
    <p class="text-6xl font-bold text-(--color-text-secondary) mb-4">404</p>
    <p class="text-lg text-(--color-text-secondary) mb-8">페이지를 찾을 수 없습니다.</p>
    <div class="flex gap-3">
      <a href="/" class="px-4 py-2 rounded-lg bg-(--color-accent-dev) text-white text-sm hover:opacity-90 transition-opacity">
        홈으로
      </a>
      <a href="/archive/" class="px-4 py-2 rounded-lg border border-(--color-border) text-sm text-(--color-text-secondary) hover:text-(--color-text) hover:border-(--color-text-secondary) transition-colors">
        아카이브
      </a>
    </div>
  </div>
</BaseLayout>
