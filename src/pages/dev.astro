---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts'))
  .filter((p) => !p.data.draft && p.data.category === 'dev')
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="코딩 - Ethan's Blog" description="기술 학습, 개발 경험, 트러블슈팅">
  <h1 class="text-3xl font-bold mb-2">💻 코딩</h1>
  <p class="text-(--color-text-secondary) mb-8">기술 학습, 개발 경험, 트러블슈팅</p>
  {posts.length === 0 ? (
    <p class="text-(--color-text-secondary)">아직 글이 없습니다.</p>
  ) : (
    <div class="space-y-4">
      {posts.map((post) => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          category={post.data.category}
          pubDate={post.data.pubDate}
          tags={post.data.tags}
          slug={post.id}
          body={post.body}
        />
      ))}
    </div>
  )}
</BaseLayout>
